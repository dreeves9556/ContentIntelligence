generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String?        @unique
  emailVerified DateTime?
  name          String?
  password      String?        // For credentials auth, nullable for OAuth
  image         String?
  role          UserRole       @default(USER)
  plan          UserPlan       @default(CALENDAR_ONLY)
  tokenVersion  Int            @default(0)  // Incremented on password reset to invalidate existing JWTs
  emailUnsubscribed Boolean     @default(false) // User opted out of broadcast emails
  authorDisplayName  String?  // Public byline name shown on articles
  authorImage        String?  // URL to headshot
  authorOrganization String?  // Optional org/title shown under name
  authorContactEmail String?  // Optional contact email shown as mailto link in byline
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  questionnaires Questionnaire[]
  calendars     Calendar[]
  socialTokens  SocialToken[]
  adminMessages AdminMessage[]
  socialProfiles   SocialProfile[]
  postAnalytics    PostAnalytics[]
  contentArchives  ContentArchive[]
  contentFeedback  ContentFeedback[]
  pushSubscriptions PushSubscription[]
  profileSurveys   ProfileSurvey[]
  zernioAccounts   ZernioAccount[]
  bestTimeToPosts  BestTimeToPost[]
  followerStats    FollowerStats[]
  deepAnalytics    DeepAnalytics[]
  resourcePosts    ResourcePost[]
  bugReports      BugReport[]
  creatorMemories CreatorMemory[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Questionnaire {
  id          String   @id @default(uuid())
  title       String
  description String?
  content     Json     // Store questionnaire structure as JSON
  isPublished Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("questionnaires")
}

model Calendar {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekNumber  Int      @default(1)
  contentJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("calendars")
}

model AnalyticsCache {
  id         String   @id @default(uuid())
  key        String   @unique
  data       Json
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("analytics_cache")
}

model SocialToken {
  id           String       @id @default(uuid())
  provider     SocialProvider
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([userId, provider])
  @@map("social_tokens")
}

model AdminMessage {
  id        String   @id @default(uuid())
  subject   String
  message   String
  isRead    Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_messages")
}

model InviteToken {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  plan      UserPlan @default(CALENDAR_ONLY)

  @@map("invite_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, token])
  @@map("password_reset_tokens")
}

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  CALENDAR_ONLY
  CREATOR
  PRO
}

model SocialProfile {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // e.g., "INSTAGRAM"
  accountId    String   // The external ID
  accessToken  String?
  handle       String?
  connectedAt  DateTime @default(now())

  @@map("social_profiles")
}

model ContentArchive {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStarting   String
  dayIndex       Int
  day            String
  format         String
  bucket         String
  title          String
  hook           String
  body           String
  cta            String
  caption        String
  musicSuggestion String?
  duration       String?
  archivedAt     DateTime @default(now())

  @@unique([userId, weekStarting, dayIndex])
  @@map("content_archives")
}

model ContentFeedback {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStarting String
  dayIndex     Int
  title        String
  format       String
  bucket       String
  feedback     String   // "up" | "down"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, weekStarting, dayIndex])
  @@map("content_feedback")
}

model PostAnalytics {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalId   String?  // Platform post ID from Zernio
  title        String
  format       String   // REEL, CAROUSEL, STATIC or platform name
  publishedAt  DateTime
  views        Int      @default(0)
  likes        Int      @default(0)
  comments     Int      @default(0)
  postUrl      String?  // Direct URL to the post on the platform

  @@unique([externalId, userId])
  @@map("post_analytics")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("push_subscriptions")
}

enum SocialProvider {
  GOOGLE
  FACEBOOK
  TWITTER
  LINKEDIN
  GITHUB
}

model ProfileSurvey {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  surveyType  String
  answersJson Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, surveyType])
  @@map("profile_surveys")
}

model ZernioAccount {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  zernioProfileId String
  zernioAccountId String
  platform        String    // e.g. "instagram", "tiktok", "linkedin"
  handle          String?
  connectedAt     DateTime  @default(now())
  lastSyncAt      DateTime?

  @@unique([userId, platform])
  @@map("zernio_accounts")
}

model PlatformConfig {
  id                          String   @id @default("default")
  zernioApiKey                String?
  zernioEnabledPlatforms      String[] @default(["instagram", "tiktok", "facebook", "youtube"])
  analyticsSyncFrequencyMinutes Int    @default(60)
  anthropicModel              String   @default("claude-opus-4-8")
  anthropicApiKey             String?
  insightPromptTemplate       String?
  calendarPromptTemplate      String?
  calendarStrategyPromptTemplate String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@map("platform_config")
}

model ResourcePost {
  id          String    @id @default(cuid())
  title       String
  content     String    // HTML from Tiptap
  category    String?   // e.g. "Strategy", "Tools", "Mindset"
  published   Boolean   @default(false)
  publishedAt DateTime?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("resource_posts")
}

enum BugReportStatus {
  OPEN
  INVESTIGATED
  SOLVED
}

model BugReport {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  email       String
  deviceInfo  String          // "mobile" or "browser" — user-reported
  description String
  status      BugReportStatus @default(OPEN)
  adminNotes  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("bug_reports")
}

model FollowerStats {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform      String   // e.g. "instagram", "tiktok", "linkedin"
  date          DateTime // The day the follower count was recorded (date-only, stored at midnight UTC)
  followerCount Int      @default(0)
  growthDelta   Int      @default(0)   // net new followers vs previous day
  growthPercent Float    @default(0)   // percentage growth vs previous day
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, platform, date])
  @@map("follower_stats")
}

model BestTimeToPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String   // e.g. "instagram", "tiktok", "linkedin"
  heatmap   Json     // { grid: number[7][24], bestSlots: [{day,hour,engagement}] }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform])
  @@map("best_time_to_post")
}

model DeepAnalytics {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform  String   // e.g. "instagram", "youtube", "tiktok", "linkedin", "facebook"
  dataType  String   // e.g. "demographics", "account_insights", "retention", "channel_insights", etc.
  data      Json     // Normalized deep analytics payload
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, platform, dataType])
  @@map("deep_analytics")
}

enum MemoryType {
  IDENTITY
  VOICE
  AUDIENCE
  CONTENT
  PERFORMANCE
  STRATEGY
  PREFERENCE
  WARNING
}

enum Importance {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MemorySource {
  QUESTIONNAIRE
  PROFILE_SURVEY
  ANALYTICS
  CONTENT_FEEDBACK
  AI_GENERATED
  ADMIN
  SYSTEM
}

model CreatorMemory {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  memoryType  MemoryType
  title       String
  summary     String
  evidence    String?
  confidence  Int         @default(50) // 0-100
  importance  Importance  @default(MEDIUM)
  source      MemorySource @default(SYSTEM)
  metadata    Json?
  embedding   String?     // Nullable — reserved for future vector support (pgvector / OpenAI embeddings)
  pinned      Boolean     @default(false) // User-pinned memories always included in prompts
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lastUsedAt  DateTime?

  @@index([userId, memoryType])
  @@index([userId, importance])
  @@map("creator_memories")
}

model ScheduledBroadcast {
  id            String   @id @default(cuid())
  subject       String
  htmlContent   String
  segment       String
  scheduledFor  DateTime
  status        String   @default("PENDING") // PENDING, SENT, CANCELLED, FAILED
  sentCount     Int      @default(0)
  failedCount   Int      @default(0)
  errors        Json?
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, scheduledFor])
  @@map("scheduled_broadcasts")
}
